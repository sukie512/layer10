      "ingest_version": "v1.0"
    },
    {
      "artifact_id": "msg-010",
      "source_type": "email",
      "timestamp": "2001-08-14T07:30:00Z",
      "content": "Ken,\n\nFor personal reasons I am resigning as CEO effective immediately. I recommend you resume the CEO title. This has nothing to do with the company's financial condition.\n\nJeff Skilling",
      "metadata": {
        "from": "jeffrey.skilling@enron.com",
        "to": [
          "kenneth.lay@enron.com"
        ],
        "cc": [],
        "subject": "My Resignation",
        "thread_id": "thread-epsilon",
        "message_id": "<010@enron.com>"
      },
      "redacted": false,
      "ingest_version": "v1.0"
    }
